<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFD4EC"
    android:columnCount="2"
    android:rowCount="5"
    android:useDefaultMargins="true"
    tools:context="nielsj.crypto.view.FormattingControl">

    <TextView
        android:id="@+id/welcomeTextView"
        android:text="Formatting"
        android:layout_row="0"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:background="#42ADF5"
        android:layout_width="match_parent"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="#FFFFFF"></TextView>

    <TextView
        android:id="@+id/textGuide"
        android:text="Type text:"
        android:layout_row="1"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#000000"></TextView>

    <EditText
        android:id="@+id/textEditText"
        android:layout_row="1"
        android:layout_column="1"
        android:textSize="15sp"
        android:textColor="#000000"></EditText>


    <TextView
        android:id="@+id/guideBytes"
        android:text="-> bytes\n(0..255)"
        android:layout_row="2"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#000000"></TextView>

    <EditText
        android:id="@+id/bytesEditText"
        android:layout_row="2"
        android:layout_column="1"
        android:textSize="15sp"
        android:textColor="#000000"></EditText>

    <TextView
        android:id="@+id/guideBits"
        android:text="-> bits\n(00000000..\n..11111111)"
        android:layout_row="3"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:textSize="15sp"></TextView>

    <EditText
        android:id="@+id/bitsEditText"
        android:layout_row="3"
        android:layout_column="1"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#000000"></EditText>

    <TextView
        android:id="@+id/guideHexes"
        android:text="-> hexes\n(00..FF)"
        android:layout_row="4"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:textSize="15sp"></TextView>

    <EditText
        android:id="@+id/hexesEditText"
        android:layout_row="4"
        android:layout_column="1"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#000000"></EditText>

</GridLayout>