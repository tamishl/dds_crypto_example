<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFD4EC"
    android:columnCount="2"
    android:rowCount="8"
    android:useDefaultMargins="true"
    tools:context="nielsj.crypto.control.AESControl">

    <TextView
        android:id="@+id/welcomeTextView"
        android:layout_row="0"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:background="#42ADF5"
        android:layout_width="match_parent"
        android:paddingLeft="5dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:textColor="#FFFFFF"></TextView>

    <RadioGroup
        android:id="@+id/modeRadioGroup"
        android:layout_row="1"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/ecbRadioButton"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="ECB"
            android:checked="true"
            android:textSize="15sp"></RadioButton>

        <RadioButton
            android:id="@+id/cbcRadioButton"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="CBC"
            android:checked="false"
            android:textSize="15sp"></RadioButton>
    </RadioGroup>

    <RadioGroup
        android:id="@+id/paddingRadioGroup"
        android:layout_row="2"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/noPaddingRadioButton"
            android:checked="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="No padding  "
            android:textSize="15sp"></RadioButton>

        <RadioButton
            android:id="@+id/paddingRadioButton"
            android:checked="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="PKCS5Padding"
            android:textSize="15sp"></RadioButton>
    </RadioGroup>



    <TextView
        android:id="@+id/guideTextView"
        android:text="Type\nplaintext"
        android:textColor="#000000"
        android:layout_row="3"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"></TextView>

    <EditText
        android:id="@+id/plaintextEditText"
        android:layout_row="3"
        android:layout_column="1"
        android:textSize="14sp"
        android:textColor="#992020"
        android:textStyle="bold"
        android:typeface="monospace"
        android:inputType="text"></EditText>

    <TextView
        android:id="@+id/keyTextView"
        android:text="Key"
        android:textColor="#000000"
        android:layout_row="4"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"></TextView>

    <EditText
        android:id="@+id/keyEditText"
        android:layout_row="4"
        android:layout_column="1"
        android:textSize="14sp"
        android:textColor="#992020"
        android:textStyle="bold"
        android:typeface="monospace"
        android:inputType="text"></EditText>

    <TextView
        android:id="@+id/keyTextView"
        android:text="IV"
        android:textColor="#000000"
        android:layout_row="5"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"></TextView>

    <EditText
        android:id="@+id/ivEditText"
        android:layout_row="5"
        android:layout_column="1"
        android:textSize="14sp"
        android:textColor="#209920"
        android:textStyle="bold"
        android:typeface="monospace"
        android:inputType="text"></EditText>



    <Button
        android:id="@+id/encryptButton"
        android:text="Encrypt"
        android:layout_row="6"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"></Button>

    <EditText
        android:id="@+id/encryptedEditText"
        android:layout_row="6"
        android:layout_column="1"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textColor="#209920"
        android:textStyle="bold"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:typeface="monospace"
        android:inputType="textMultiLine"></EditText>

    <Button
        android:id="@+id/decryptButton"
        android:text="Decrypt"
        android:layout_row="7"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"></Button>

    <TextView
        android:id="@+id/decryptedTextView"
        android:layout_row="7"
        android:layout_column="1"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textColor="#992020"
        android:textStyle="bold"
        android:typeface="monospace"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:inputType="textMultiLine">
    </TextView>

</GridLayout>