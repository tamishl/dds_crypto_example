<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFD4EC"
    android:rowCount="7"
    android:columnCount="2"
    android:useDefaultMargins="true"
    tools:context="nielsj.crypto.exercises.AESCracker">

    <TextView
        android:id="@+id/welcomeTextView"
        android:text="Welcome to the AES cracker"
        android:layout_row="0"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:background="#42ADF5"
        android:layout_width="match_parent"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="#FFFFFF"></TextView>

    <TextView
        android:id="@+id/guideTextView"
        android:text="Please type ciphertext:"
        android:layout_row="1"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="#000000"></TextView>

    <EditText
        android:id="@+id/cipherEditText"
        android:layout_row="2"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:textSize="14sp"
        android:textColor="#000000"
        android:typeface="monospace"
        android:inputType="text"></EditText>

    <Button
        android:id="@+id/crackButton"
        android:text="Crack"
        android:layout_row="3"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAllCaps="false"
        android:textSize="15sp"> </Button>

    <Button
        android:id="@+id/clearButton"
        android:text="Clear"
        android:layout_row="4"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAllCaps="false"
        android:textSize="15sp"> </Button>

    <TextView
        android:id="@+id/keyName"
        android:text="Key:"
        android:layout_row="5"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textColor="#000000"></TextView>




    <TextView
        android:id="@+id/keyValue"
        android:text="(key value)"
        android:layout_row="5"
        android:layout_column="1"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textColor="#000000"></TextView>



    <TextView
        android:id="@+id/plaintextName"
        android:text="Plaintext:"
        android:layout_row="6"
        android:layout_column="0"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textColor="#000000"></TextView>

    <TextView
        android:id="@+id/plaintextValue"
        android:text="(plaintext value)"
        android:layout_row="6"
        android:layout_column="1"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textColor="#000000"></TextView>

</GridLayout>
