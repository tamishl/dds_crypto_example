<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="crypto"
        android:supportsRtl="true"
        android:theme="@style/Theme.Crypto"
        tools:targetApi="31">
        <activity
            android:name="nielsj.crypto.Crypto"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="nielsj.crypto.control.SymmetricEncryptionControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.control.CaesarControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.control.AESControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.control.HashingControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.control.AsymmetricEncryptionControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.control.RSAControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.control.DiffieHellmanControl"
            android:exported="false">
        </activity>
        <activity
            android:name="nielsj.crypto.view.FormattingControl"
            android:exported="false">
        </activity>

    </application>

</manifest>